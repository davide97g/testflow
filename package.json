{
  "name": "@davide97g/testflow",
  "version": "0.1.1",
  "description": "Framework for testing and automation",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "default": "./dist/env.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "build:types": "tsc --emitDeclarationOnly",
    "prepublishOnly": "bun run build && bun run build:types",
    "test": "echo \"Error: no test specified\" && exit 1",
    "extract": "bun run scripts/get-jira-issue.ts",
    "extract:jira": "bun run scripts/get-jira-issue.ts",
    "extract:pr": "bun run scripts/get-pr-changes.ts",
    "init": "bun run src/init.ts",
    "sonar:fetch": "npx @bitrockteam/sonarflow fetch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davide97g/testflow.git"
  },
  "keywords": [
    "testflow",
    "testing",
    "automation",
    "jira",
    "bitbucket",
    "cli"
  ],
  "author": "Davide Ghiotto",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/davide97g/testflow/issues"
  },
  "homepage": "https://github.com/davide97g/testflow#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.0.1",
    "@types/fs-extra": "^11.0.4",
    "axios": "^1.13.2",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "figlet": "^1.9.4",
    "fs-extra": "^11.3.2",
    "gradient-string": "^3.0.0",
    "ora": "^9.0.0",
    "zod": "^4.1.12"
  },
  "bin": {
    "testflow": "./dist/cli.js"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
