{
  "name": "ai-test-validation",
  "version": "1.0.0",
  "description": "AI-Assisted Test Validation system for automated regression testing",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "fetch-tests": "bun cli/fetch-tests.ts",
    "run-tests": "bun cli/run-tests.ts",
    "report": "bun cli/report.ts",
    "setup-env": "./scripts/setup-env.sh",
    "type-check": "tsc --noEmit",
    "lint": "bunx @biomejs/biome lint .",
    "format": "bunx @biomejs/biome format --write .",
    "check": "bunx @biomejs/biome check .",
    "check:fix": "bunx @biomejs/biome check --write ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davide97g/testflow.git"
  },
  "keywords": [
    "testing",
    "ai",
    "zephyr",
    "jira",
    "bitbucket",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/davide97g/testflow/issues"
  },
  "homepage": "https://github.com/davide97g/testflow#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.2",
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
