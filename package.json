{
  "name": "testflow",
  "version": "0.2.0",
  "description": "Framework for automating testing with Playwright and AI",
  "author": "Bitrock",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "ELECTRON_DEV=1 concurrently \"vite --cwd renderer\" \"electron .\"",
    "build:renderer": "cd renderer && vite build",
    "build": "npm run build:renderer && electron-builder",
    "prestart": "npm run build:renderer"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "express": "^4.18.2",
    "open": "^8.4.0",
    "cross-spawn": "^7.0.5",
    "playwright": "^1.40.0"
  },
  "devDependencies": {
    "electron": "^26.0.0",
    "concurrently": "^8.0.0",
    "vite": "^5.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "electron-builder": "^24.9.1"
  }
}
